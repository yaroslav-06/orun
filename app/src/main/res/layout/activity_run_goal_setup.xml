<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Set a goal"
            android:textAppearance="?attr/textAppearanceTitleLarge" />

        <!-- No goal content -->
        <LinearLayout
            android:id="@+id/llNoGoalContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_trophy"
                android:tint="?attr/colorPrimary" />

            <TextView
                android:id="@+id/tvNoGoalTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:textAppearance="?attr/textAppearanceHeadlineMedium" />

            <TextView
                android:id="@+id/tvNoGoalSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="?attr/colorOnSurfaceVariant" />

        </LinearLayout>

        <!-- Distance input -->
        <LinearLayout
            android:id="@+id/llDistanceContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone">

            <EditText
                android:id="@+id/etDistanceGoal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="e.g. 5"
                android:imeOptions="actionDone"
                android:inputType="numberDecimal"
                android:textSize="32sp" />

            <TextView
                android:id="@+id/tvDistanceUnit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="km"
                android:textSize="24sp" />

        </LinearLayout>

        <!-- Duration clock -->
        <LinearLayout
            android:id="@+id/llDurationContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="bottom"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvHours"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00"
                    android:textSize="48sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="2dp"
                    android:layout_marginEnd="14dp"
                    android:paddingBottom="7dp"
                    android:text="h"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/tvMinutes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00"
                    android:textSize="48sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="2dp"
                    android:layout_marginEnd="14dp"
                    android:paddingBottom="7dp"
                    android:text="m"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/tvSeconds"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00"
                    android:textSize="48sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="2dp"
                    android:paddingBottom="7dp"
                    android:text="s"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="16sp" />

            </LinearLayout>

            <!-- Invisible EditText captures keyboard digits -->
            <EditText
                android:id="@+id/etDurationInput"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:alpha="0"
                android:inputType="number"
                android:maxLength="6" />

        </LinearLayout>

        <!-- Spacer pushes chips + toggle + button to the bottom -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Preset chips — shown for Distance or Duration -->
        <LinearLayout
            android:id="@+id/llChipsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:orientation="vertical"
            android:visibility="gone">

            <HorizontalScrollView
                android:id="@+id/hsvDistanceChips"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="4dp">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipDist5k"
                        style="@style/Widget.Material3.Chip.Suggestion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:text="5K" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipDist10k"
                        style="@style/Widget.Material3.Chip.Suggestion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:text="10K" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipDistHalf"
                        style="@style/Widget.Material3.Chip.Suggestion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:text="Half" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipDistMarathon"
                        style="@style/Widget.Material3.Chip.Suggestion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Marathon" />

                </LinearLayout>

            </HorizontalScrollView>

            <HorizontalScrollView
                android:id="@+id/hsvDurationChips"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="4dp">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipDur10m"
                        style="@style/Widget.Material3.Chip.Suggestion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:text="10 min" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipDur30m"
                        style="@style/Widget.Material3.Chip.Suggestion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:text="30 min" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipDur1h"
                        style="@style/Widget.Material3.Chip.Suggestion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1 hr" />

                </LinearLayout>

            </HorizontalScrollView>

        </LinearLayout>

        <!-- Goal type toggle at the bottom -->
        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggleGoalType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:checkedButton="@id/btnNoGoal"
            app:selectionRequired="true"
            app:singleSelection="true">

            <Button
                android:id="@+id/btnNoGoal"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="No goal" />

            <Button
                android:id="@+id/btnDistance"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Distance" />

            <Button
                android:id="@+id/btnDuration"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Duration" />

        </com.google.android.material.button.MaterialButtonToggleGroup>

        <Button
            android:id="@+id/btnStartRun"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Start Run" />

    </LinearLayout>

</ScrollView>
