class UnitPreference <<see: services.puml>> #DDDDDD
class FormatUtils <<see: services.puml>> #DDDDDD
class LocationTrackingService <<see: services.puml>> #DDDDDD

' ── Stubs referencing activities.puml ────────────────────────────────────────
class RunStatsActivity <<see: activities.puml>> #DDDDDD
class RunDetailActivity <<see: activities.puml>> #DDDDDD
class SettingsActivity <<see: activities.puml>> #DDDDDD
class DistanceEffortsActivity <<see: activities.puml>> #DDDDDD
class RunGoalSetupActivity <<see: activities.puml>> #DDDDDD

HomeFragment --|> Fragment
MapFragment --|> Fragment
AchievementsFragment --|> Fragment

MapFragment *-- DoubleTapZoomOverlay : inner class

HomeFragment ..> RunDatabase : uses
HomeFragment ..> Run : creates
HomeFragment ..> LocationTrackingService : starts
HomeFragment ..> RunGoalSetupActivity : launches
HomeFragment ..> RunStatsActivity : opens
HomeFragment ..> RunDetailActivity : opens
HomeFragment ..> SettingsActivity : opens
HomeFragment ..> RunStats : observes
HomeFragment *-- RunAdapter : uses

RunAdapter ..> Run : displays
RunAdapter ..> UnitPreference : reads
RunAdapter ..> FormatUtils : uses

MapFragment ..> RunDatabase : uses

AchievementsFragment ..> RunDatabase : uses
AchievementsFragment ..> BestEffort : displays
AchievementsFragment ..> UnitPreference : reads
AchievementsFragment ..> FormatUtils : uses
AchievementsFragment ..> DistanceEffortsActivity : opens

@enduml
