@startuml Fragments

abstract class Fragment <<Android>>

class HomeFragment {
    -adapter : RunAdapter
    -scope : CoroutineScope
    -mainScope : CoroutineScope
    -observeJob : Job
    -listJob : Job
    +onCreateView(...) : View
    +onResume()
    +onPause()
    -launchGoalSetup()
    -startRun(goalDistanceMeters : Float?, goalDurationMs : Long?)
    -updateFab(stats : RunStats)
}

class MapFragment {
    -map : MapView
    -fusedLocationClient : FusedLocationProviderClient
    -fabMyLocation : FloatingActionButton
    -myLocationOverlay : MyLocationNewOverlay
    -scope : CoroutineScope
    +onCreateView(...) : View
    +onResume()
    +onPause()
    +onDestroyView()
    -goToMyLocation()
}

class DoubleTapZoomOverlay {
    -pixelsPerZoomLevel : Float
    -isDoubleTapDragging : Boolean
    -startY : Float
    -startZoomLevel : Double
    -totalDragDistance : Float
    -gestureDetector : GestureDetectorCompat
    +onTouchEvent(event, mapView) : Boolean
}

class AchievementsFragment {
    -scope : CoroutineScope
    +onCreateView(...) : View
    +onViewCreated(view : View, savedInstanceState : Bundle?)
    +onDestroyView()
}

class RunAdapter {
    -runs : List<Run>
    -onClick : (Run) -> Unit
    +submitList(newRuns : List<Run>)
    +onCreateViewHolder(...) : ViewHolder
    +onBindViewHolder(...)
    +getItemCount() : Int
    -formatDate(ms : Long) : String
}

